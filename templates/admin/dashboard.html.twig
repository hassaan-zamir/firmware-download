{% extends '@EasyAdmin/page/content.html.twig' %}

{% block page_title %}BimmerTech Firmware Manager{% endblock %}

{% block content_body %}
<div style="padding: 20px;">
    <h2>Welcome to the BimmerTech Firmware Manager</h2>
    <p>Use this admin panel to manage firmware versions for CarPlay / Android Auto MMI devices.</p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 30px;">
        <div style="background: #f8f9fa; border-radius: 8px; padding: 24px; border: 1px solid #e9ecef;">
            <h3 style="margin-top: 0;">📦 Software Versions</h3>
            <p>Add, edit, or remove firmware versions. Each version is linked to download URLs for ST and/or GD hardware variants.</p>
            <a href="{{ ea_url().setController('App\\\\Controller\\\\Admin\\\\SoftwareVersionCrudController').setAction('index') }}" 
               style="color: #1CA3C2; text-decoration: underline;">Manage Versions →</a>
        </div>
        
        <div style="background: #f8f9fa; border-radius: 8px; padding: 24px; border: 1px solid #e9ecef;">
            <h3 style="margin-top: 0;">🌐 Customer Page</h3>
            <p>View the public-facing download page where customers enter their device details to get the correct firmware.</p>
            <a href="{{ path('software_download') }}" target="_blank" 
               style="color: #1CA3C2; text-decoration: underline;">Open Customer Page →</a>
        </div>

        <div style="background: #fff3cd; border-radius: 8px; padding: 24px; border: 1px solid #ffc107;">
            <h3 style="margin-top: 0;">⚠️ Important Notes</h3>
            <ul style="padding-left: 20px;">
                <li>Only <strong>one version per product group</strong> should be marked as "Latest"</li>
                <li><strong>LCI fields</strong> (isLci, lciHwType) are auto-calculated from the product name</li>
                <li><strong>Version Alt</strong> is the lookup key — it must match what customers see on their devices (without the "v" prefix)</li>
            </ul>
        </div>
    </div>
</div>
{% endblock %}
